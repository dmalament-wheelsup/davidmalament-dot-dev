---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import ProjectCard from "../components/ProjectCard.astro";
import Footer from "../components/Footer.astro";
import { projects, skills } from "../data/projects";
---

<Layout>
  <Nav />
  <main>
    <Hero />

    <Section id="about" eyebrow="About" title="A bit about me.">
      <div class="space-y-4 text-[color:var(--color-muted)] leading-relaxed">
        <p>
          I'm a software engineer who cares about the craft. I like systems that
          are simple at the surface and rigorous underneath — code that's easy
          to delete, fast by default, and pleasant to live with.
        </p>
        <p>
          Most of my work is on the web, across the full stack. I spend my time
          shipping features, untangling performance problems, and pushing for
          the small details that make products feel sharp.
        </p>
      </div>
    </Section>

    <Section id="skills" eyebrow="Toolkit" title="What I work with.">
      <div class="grid sm:grid-cols-2 gap-6">
        {
          skills.map((group) => (
            <div>
              <h3 class="text-sm font-mono text-[color:var(--color-fg)]">
                {group.group}
              </h3>
              <ul class="mt-3 flex flex-wrap gap-2">
                {group.items.map((item) => (
                  <li class="rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-surface)] px-3 py-1 text-xs text-[color:var(--color-muted)]">
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </Section>

    <Section id="projects" eyebrow="Selected work" title="Things I've built.">
      <div class="grid gap-4 sm:grid-cols-2">
        {projects.map((p) => <ProjectCard project={p} />)}
      </div>
    </Section>

    <Section id="contact" eyebrow="Contact" title="Let's talk.">
      <p class="text-[color:var(--color-muted)] leading-relaxed">
        The fastest way to reach me is email. I'm always happy to chat about
        interesting work, hard problems, or anything in between.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href="mailto:david.malament@gmail.com"
          class="inline-flex items-center gap-2 rounded-md bg-[color:var(--color-fg)] px-4 py-2 text-sm font-medium text-[color:var(--color-bg)] hover:bg-[color:var(--color-accent)] transition-colors"
        >
          ./email
        </a>
        <a
          href="https://github.com/"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-bg)]/60 px-4 py-2 text-sm font-medium hover:border-[color:var(--color-accent)] transition-colors"
        >
          ./github
        </a>
        <a
          href="https://www.linkedin.com/"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-bg)]/60 px-4 py-2 text-sm font-medium hover:border-[color:var(--color-accent)] transition-colors"
        >
          ./linkedin
        </a>
      </div>
    </Section>
  </main>
  <Footer />
</Layout>

<script>
  const targets = document.querySelectorAll(".reveal");
  if ("IntersectionObserver" in window) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          entry.target.classList.add("is-visible");
          io.unobserve(entry.target);
        }
      },
      { rootMargin: "0px 0px -10% 0px", threshold: 0.1 },
    );
    targets.forEach((el) => io.observe(el));
  } else {
    targets.forEach((el) => el.classList.add("is-visible"));
  }
</script>
