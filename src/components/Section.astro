---
interface Props {
  id: string;
  eyebrow: string;
  title: string;
}
const { id, eyebrow, title } = Astro.props;
---

<section id={id} class="mx-auto max-w-3xl px-6 py-20 scroll-mt-20">
  <div class="reveal">
    <p class="font-mono text-xs uppercase tracking-[0.18em] text-[color:var(--color-accent)]">
      {eyebrow}
    </p>
    <h2 class="mt-2 text-3xl sm:text-4xl font-semibold tracking-tight">
      {title}
    </h2>
    <div class="mt-8">
      <slot />
    </div>
  </div>
</section>
