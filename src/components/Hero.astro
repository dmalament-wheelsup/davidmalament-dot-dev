---
import { Image } from "astro:assets";
import profile from "../assets/profile.jpg";

const titles = [
  "Software",
  "Frontend",
  "Backend",
  "Mobile",
  "Database",
  "AI",
  "Fullstack",
];
---

<section
  id="top"
  class="relative mx-auto max-w-3xl px-6 pt-24 pb-20 sm:pt-32 sm:pb-28"
>
  <div class="flex flex-col-reverse sm:flex-row sm:items-center sm:gap-10">
    <div class="flex-1 min-w-0">
      <p
        class="fade-up text-sm text-[color:var(--color-muted)]"
      >
        > whoami
      </p>
      <h1
        class="fade-up mt-3 text-3xl sm:text-5xl font-semibold tracking-tight leading-[1.15]"
      >
        Hi, I'm <span class="text-[color:var(--color-accent)] whitespace-nowrap">David Malament</span>.
      </h1>
      <p
        class="fade-up mt-2 text-3xl sm:text-5xl font-semibold tracking-tight leading-[1.15] whitespace-nowrap"
      >
        <span class="text-[color:var(--color-muted)]">&gt;</span><span
          class="rotator ml-[0.35ch]"
          data-titles={JSON.stringify(titles)}
          aria-live="polite"
          aria-label="Software Engineer"
        ><span class="rotator__text">{titles[0]}</span><span class="caret" aria-hidden="true"></span></span> Engineer
      </p>
      <p
        class="fade-up mt-6 text-base text-[color:var(--color-muted)] max-w-xl leading-relaxed"
      >
        I'm a product-minded engineer with a designer's eye. Code was always
        just the medium — now AI handles the assembly so I can focus on the
        product itself.
      </p>
      <div class="fade-up mt-8 flex items-center gap-3">
        <a
          href="#projects"
          class="inline-flex items-center gap-2 rounded-md bg-[color:var(--color-fg)] px-4 py-2 text-sm font-medium text-[color:var(--color-bg)] hover:bg-[color:var(--color-accent)] transition-colors"
        >
          ./view-work
        </a>
        <a
          href="#contact"
          class="inline-flex items-center gap-2 rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-bg)]/60 px-4 py-2 text-sm font-medium text-[color:var(--color-fg)] hover:border-[color:var(--color-accent)] transition-colors"
        >
          ./contact
        </a>
      </div>
    </div>

    <div class="fade-up shrink-0 mb-6 sm:mb-0">
      <div
        class="relative w-28 h-28 sm:w-40 sm:h-40 rounded-full overflow-hidden border border-[color:var(--color-border)] bg-[color:var(--color-surface)] shadow-sm"
      >
        <Image
          src={profile}
          alt="Portrait of David Malament"
          width={320}
          height={320}
          quality={80}
          format="webp"
          loading="eager"
          class="w-full h-full object-cover"
        />
      </div>
    </div>
  </div>
</section>

<script>
  const root = document.querySelector<HTMLElement>(".rotator");
  if (root) {
    const titles: string[] = JSON.parse(root.dataset.titles || "[]");
    const textEl = root.querySelector<HTMLElement>(".rotator__text");
    const reduce = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    const TYPE_MS = 80;
    const ERASE_MS = 45;
    const HOLD_AFTER_TYPE = 2000;
    const HOLD_AFTER_ERASE = 250;
    const JITTER = 30;

    const sleep = (ms: number) =>
      new Promise((r) => setTimeout(r, ms + Math.random() * JITTER));

    if (textEl && titles.length > 1 && !reduce) {
      const setTyping = (typing: boolean) => {
        document.body.classList.toggle("is-typing", typing);
      };

      const run = async () => {
        let i = 0;
        // Initial word is already rendered — give the user a moment to read it.
        await sleep(HOLD_AFTER_TYPE);

        while (true) {
          const current = titles[i];
          const next = titles[(i + 1) % titles.length];

          setTyping(true);
          for (let n = current.length; n >= 0; n--) {
            textEl.textContent = current.slice(0, n);
            await sleep(ERASE_MS);
          }
          setTyping(false);
          await sleep(HOLD_AFTER_ERASE);

          setTyping(true);
          for (let n = 1; n <= next.length; n++) {
            textEl.textContent = next.slice(0, n);
            await sleep(TYPE_MS);
          }
          setTyping(false);

          root.setAttribute("aria-label", `${next} Engineer`);
          i = (i + 1) % titles.length;
          await sleep(HOLD_AFTER_TYPE);
        }
      };

      run();
    }
  }
</script>
