---
import type { Project } from "../data/projects";
interface Props {
  project: Project;
}
const { project } = Astro.props;
---

<article
  class="group relative rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-surface)] p-6 transition-all hover:border-[color:var(--color-accent)] hover:-translate-y-0.5"
>
  <div class="flex items-start justify-between gap-4">
    <h3 class="text-lg font-semibold tracking-tight">{project.name}</h3>
    <div class="flex items-center gap-3 text-[color:var(--color-muted)]">
      {
        project.repo && (
          <a
            href={project.repo}
            target="_blank"
            rel="noopener"
            aria-label={`${project.name} repository`}
            class="hover:text-[color:var(--color-fg)] transition-colors"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2c-3.2.7-3.87-1.37-3.87-1.37-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.24 3.34.95.1-.74.4-1.24.73-1.53-2.55-.29-5.24-1.27-5.24-5.66 0-1.25.45-2.27 1.18-3.07-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.17a10.94 10.94 0 0 1 5.74 0c2.18-1.48 3.15-1.17 3.15-1.17.62 1.58.23 2.75.11 3.04.74.8 1.18 1.82 1.18 3.07 0 4.4-2.69 5.36-5.25 5.65.41.36.78 1.06.78 2.13v3.16c0 .31.21.68.8.56 4.57-1.52 7.85-5.83 7.85-10.91C23.5 5.65 18.35.5 12 .5z" />
            </svg>
          </a>
        )
      }
      {
        project.href && (
          <a
            href={project.href}
            target="_blank"
            rel="noopener"
            aria-label={`${project.name} live site`}
            class="hover:text-[color:var(--color-fg)] transition-colors"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M7 17 17 7" />
              <path d="M7 7h10v10" />
            </svg>
          </a>
        )
      }
    </div>
  </div>
  <p class="mt-3 text-sm text-[color:var(--color-muted)] leading-relaxed">
    {project.description}
  </p>
  <ul class="mt-4 flex flex-wrap gap-2">
    {
      project.stack.map((tag) => (
        <li class="rounded-full border border-[color:var(--color-border)] px-2.5 py-0.5 text-xs font-mono text-[color:var(--color-muted)]">
          {tag}
        </li>
      ))
    }
  </ul>
</article>
